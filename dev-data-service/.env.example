# Dev Data Service Configuration

# Server settings
HOST=0.0.0.0
PORT=8001

# Database settings
# Database type: sqlite, mysql
DB_TYPE=sqlite

# SQLite configuration
DATABASE_PATH=./dev_data.db

# MySQL configuration (when DB_TYPE=mysql)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=cowork_dev_data
# DB_CHARSET=utf8mb4

# Authentication (optional)
# Set REQUIRE_AUTH=true to enable API key authentication
REQUIRE_AUTH=false
API_KEY=your_secure_api_key_here
